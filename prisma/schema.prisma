generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Int
  image       String
  stock       Int      @default(0)
  category    String

  weight      String?
  unit        String?   // e.g. "1 pack", "per kg", "carton"
  description String?
  nutrients   String?
  storage     String?
  featured    Boolean   @default(false)
  available   Boolean   @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String
  address       String
  city          String
  totalAmount   Int
  status        OrderStatus @default(PENDING)
  paystackRef   String?     @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}